{
  "bindings": [
    {
      "channel": "individual.bed.temperature",
      "target": "bed.color",
      "transform": { "kind": "colormap", "name": "temperature" }
    },
    {
      "channel": "individual.bed.temperature",
      "target": "bed.heatIntensity",
      "transform": { "kind": "scale", "factor": 0.009091 }
    },
    {
      "channel": "individual.hotend.temperature",
      "target": "hotend.emissiveIntensity",
      "transform": { "kind": "scale", "factor": 0.004 }
    },
    { "channel": "individual.printer.activeTool", "target": "toolhead.colorIndex" },
    { "channel": "individual.bed.temperature", "target": "status.bedTemp" },
    { "channel": "individual.hotend.temperature", "target": "status.hotendTemp" }
  ],
  "color_maps": {
    "temperature": {
      "kind": "gradient",
      "domain": [20, 110],
      "stops": [
        { "at": 20, "color": "#252836" },
        { "at": 60, "color": "#78350f" },
        { "at": 90, "color": "#ea580c" },
        { "at": 110, "color": "#ef4444" }
      ]
    }
  },
  "scene": {
    "background": "#0a0c15",
    "environment": "city",
    "camera": {
      "position": [7, 10, 12],
      "lookAt": [0, 2.5, 0],
      "fov": 42
    },
    "objects": [
      {
        "id": "voron.static",
        "kind": "glb",
        "asset": "assets/voron-trident-350.glb",
        "position": [0, 0, 0],
        "scale": [1, 1, 1],
        "castShadow": true,
        "receiveShadow": true
      },
      {
        "id": "bed",
        "kind": "box",
        "size": [6.85, 0.05, 6.85],
        "position": [0, 0.265, 0],
        "receiveShadow": true,
        "bindings": { "emissive": "bed.color", "emissiveIntensity": "bed.heatIntensity" },
        "material": { "color": "#111827", "emissive": "#252836", "emissiveIntensity": 0.2, "roughness": 0.38, "metalness": 0.2 }
      },
      {
        "id": "toolhead",
        "kind": "sphere",
        "radius": 0.18,
        "position": [0, 5.26, -3.5],
        "bindings": { "colorIndex": "toolhead.colorIndex", "emissiveIntensity": "hotend.emissiveIntensity" },
        "material": {
          "color": "#06b6d4",
          "emissive": "#06b6d4",
          "emissiveIntensity": 0.25,
          "roughness": 0.3,
          "metalness": 0.45,
          "colorPalette": ["#06b6d4", "#f97316", "#ec4899"]
        }
      },
      { "id": "nozzle", "kind": "cone", "size": [0.055, 0.28, 8], "position": [0, 4.98, -3.5], "rotation": [3.14159, 0, 0], "material": { "color": "#b09060", "roughness": 0.28, "metalness": 0.7 } }
    ]
  }
}
